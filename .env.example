# Copy to `.env` (gitignored) and fill in real keys. Loaded automatically by the
# reviewer panel (src/wc2026/review/env.py). Real shell env vars override these.
# Recommended: chmod 600 .env

# R1 The Theorist (Anthropic)         https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# R2 The Domain Skeptic (OpenAI)      https://platform.openai.com/api-keys
OPENAI_API_KEY=

# R3 The Methodologist (Google)       https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional: override model ids without editing reviewers/config.json
# REVIEW_OPENAI_MODEL=gpt-5.5
# REVIEW_GOOGLE_MODEL=gemini-3.5-flash
# REVIEW_ANTHROPIC_MODEL=claude-opus-4-8
